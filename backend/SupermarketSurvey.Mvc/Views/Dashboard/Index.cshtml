@{ ViewData["HideAppBar"] = true; }

<div class="dashboard-header">
  <div style="display:flex;justify-content:space-between;align-items:flex-start;">
    <div>
      <h2>Good day,</h2>
      <h1>@User.Identity!.Name</h1>
    </div>
    <div class="user-avatar" style="width:44px;height:44px;font-size:1rem;">
      @(string.Concat(User.Identity.Name!.Split(' ').Take(2).Select(w => w[0].ToString().ToUpper())))
    </div>
  </div>
  @{
    var outletName = User.FindFirst("OutletName")?.Value;
  }
  @if (!string.IsNullOrEmpty(outletName))
  {
    <div style="margin-top:14px;font-size:.85rem;opacity:.75;">📍 @outletName</div>
  }
</div>

<div class="dashboard-content">

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-num">@ViewBag.SurveyCount</div>
      <div class="stat-label">Active Surveys</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">@ViewBag.OutletCount</div>
      <div class="stat-label">Outlets</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">@ViewBag.ResponseCount</div>
      <div class="stat-label">Responses</div>
    </div>
  </div>

  <div class="section-title">Quick Actions</div>
  <div class="quick-action-grid">
    <a href="/Survey/SelectOutlet" class="qa-card">
      <span class="qa-icon">🏪</span>
      <span class="qa-label">New Survey</span>
    </a>
    <a href="/Reports/Index" class="qa-card">
      <span class="qa-icon">📊</span>
      <span class="qa-label">Participation</span>
    </a>
    <a href="/Reports/Statistics" class="qa-card">
      <span class="qa-icon">📈</span>
      <span class="qa-label">Statistics</span>
    </a>
    <a href="/Account/Logout" class="qa-card">
      <span class="qa-icon">🚪</span>
      <span class="qa-label">Logout</span>
    </a>
  </div>

  <div class="section-title" style="margin-top:24px;">Available Surveys</div>

  @foreach (var survey in (IEnumerable<dynamic>)ViewBag.Surveys)
  {
    <form method="post" action="/Survey/SelectSurvey">
      @Html.AntiForgeryToken()
      <input type="hidden" name="surveyId"    value="@survey.Id" />
      <input type="hidden" name="surveyTitle" value="@survey.Title" />
      <button type="submit" class="list-item" style="width:100%;text-align:left;background:white;cursor:pointer;">
        <div class="list-item-icon">📋</div>
        <div class="list-item-body">
          <div class="list-item-title">@survey.Title</div>
          <div class="list-item-sub">@survey.Questions.Count question(s)</div>
        </div>
        <div class="list-item-arrow">›</div>
      </button>
    </form>
  }

</div>
